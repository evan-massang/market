# ═══════════════════════════════════════════
# PolySwarm Configuration
# ═══════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Only LLM_PROVIDER + its API key are required.
# Everything else has sensible defaults.
# ═══════════════════════════════════════════

# ── LLM Provider ──────────────────────────
# Choose: "anthropic", "openai", or "ollama"
LLM_PROVIDER=anthropic

# API Keys (only need ONE — the one for your chosen provider)
ANTHROPIC_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here

# OpenAI-compatible APIs (Groq, Together, etc.)
# OPENAI_BASE_URL=https://api.groq.com/openai/v1

# Ollama — free, local, no API key needed
# Set LLM_PROVIDER=ollama and ensure Ollama is running
# OLLAMA_BASE_URL=http://localhost:11434

# ── Model Overrides (optional) ────────────
# Defaults: claude-sonnet-4-20250514 / gpt-4o-mini / llama3.1:8b
# MODEL_FAST=claude-sonnet-4-20250514
# MODEL_DEEP=claude-sonnet-4-20250514

# ── Swarm Config ──────────────────────────
DEBATE_ROUNDS=2
SWARM_SIZE=12

# ═══════════════════════════════════════════
# Data Source API Keys
# All optional — sources work without keys but may be rate-limited.
# Get free keys at the URLs below.
# ═══════════════════════════════════════════

# Etherscan — ETH gas prices
# Free key: https://etherscan.io/apis
# ETHERSCAN_API_KEY=your_key_here

# CryptoPanic — crypto news headlines
# Free token: https://cryptopanic.com/developers/api/
# CRYPTOPANIC_API_KEY=your_key_here

# CoinGecko Pro — higher rate limits (free tier works fine)
# COINGECKO_API_KEY=your_key_here

# ═══════════════════════════════════════════
# Data Source Filtering (optional)
# ═══════════════════════════════════════════

# Whitelist specific sources (comma-separated, default: all available)
# Run `python main.py sources` to see all source names
# POLYSWARM_SOURCES=binance_spot,funding_rates,fear_greed,btc_options

# ═══════════════════════════════════════════
# Infrastructure
# ═══════════════════════════════════════════
REDIS_URL=redis://localhost:6379
DATABASE_URL=sqlite+aiosqlite:///./polyswarm.db

# ═══════════════════════════════════════════
# API Server (optional)
# ═══════════════════════════════════════════

# Set to require X-API-Key header on protected endpoints
# POLYSWARM_API_KEY=your_secret_key_here

# ── Supervisor / one-command orchestrator (paper-only) ───────────────────────
# Which background services `python -m harness.supervisor start` brings up.
SUPERVISOR_ENABLED=true
RUN_MIROFISH=true
RUN_MIROFISH_FRONTEND=false
RUN_DASHBOARD=true
RUN_SAMEDAY_DAEMON=true
RUN_AI_PIPELINE=true

DASHBOARD_PORT=8800
MIROFISH_BACKEND_PORT=5001

# Auto-restart a crashed REQUIRED service (capped so it can't crash-loop forever).
SUPERVISOR_RESTART_CRASHED=true
SUPERVISOR_MAX_RESTARTS=5
SUPERVISOR_RESTART_WINDOW_SECONDS=600

# ── EV-after-costs profitability filter (paper-only; tightening only) ─────────
# Bet only when after-cost EV (incl. spread/liquidity/uncertainty/exit-risk
# penalties) clears the threshold. All default to a no-op unless raised.
MIN_EV_AFTER_COSTS=0.0
SPREAD_PENALTY_MULTIPLIER=0.5
LIQUIDITY_PENALTY_MULTIPLIER=0.02
UNCERTAINTY_PENALTY_MULTIPLIER=0.02
EXIT_RISK_PENALTY_MULTIPLIER=0.03

# ── Retry/backoff for external calls (Gamma/GDELT/Wikipedia/MiroFish) ─────────
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_SECONDS=0.5
RETRY_MAX_BACKOFF_SECONDS=8.0

# ── External reasoning brain (LLM is a replaceable provider; keys handled separately) ─
# BRAIN_PROVIDER: swarm (default local) | mock | disabled (observe-only) | manus
BRAIN_PROVIDER=swarm
# MANUS_API_BASE=
# MANUS_API_KEY=
# MANUS_TIMEOUT=60
